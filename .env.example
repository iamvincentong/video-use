# ElevenLabs Scribe API key — used when VIDEO_USE_TRANSCRIBER is 'legacy' or unset
ELEVENLABS_API_KEY=

# Hugging Face token — used when VIDEO_USE_TRANSCRIBER is 'vidparse'
# Get one at https://huggingface.co/settings/tokens
# Accept terms on pyannote/speaker-diarization-3.1 and pyannote/segmentation-3.0
HF_TOKEN=

# Transcription backend: 'legacy' (ElevenLabs, default) or 'vidparse' (local)
VIDEO_USE_TRANSCRIBER=legacy
